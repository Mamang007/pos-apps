# Database Connection
# Replace with your actual database URL (Local, Supabase, Neon, etc.)
# Local: postgresql://postgres:password@localhost:5432/pos_apps
# Supabase (Pooler): postgresql://postgres.[YOUR-PROJECT-ID]:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL="postgresql://postgres:password@localhost:5432/pos_apps"

# Supabase (Direct): postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-ID].supabase.co:5432/postgres
# Required for migrations if using Supabase pooler on port 6543
DIRECT_URL="postgresql://postgres:password@localhost:5432/pos_apps"

# Authentication (Auth.js)
# Generate one: openssl rand -base64 32
AUTH_SECRET="your-secret-here" 
AUTH_URL="http://localhost:3000"
