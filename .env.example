# Supabase: postgresql://postgres.[YOUR-PROJECT-ID]:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL="postgresql://postgres:password@localhost:5432/pos_apps"

# Authentication (Auth.js)
